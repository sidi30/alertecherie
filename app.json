{
  "expo": {
    "name": "AlerteCherie",
    "slug": "alertcherie",
    "owner": "sidi30",
    "scheme": "alertcherie",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.sidi30.alertcherie",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sidi30.alertcherie",
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_NOTIFICATION_POLICY",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/alarm.wav"
          ]
        }
      ],
      "expo-asset",
      "expo-audio"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b09a1735-f4cc-44ec-9b21-cc1ba7786678"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/b09a1735-f4cc-44ec-9b21-cc1ba7786678"
    }
  }
}
